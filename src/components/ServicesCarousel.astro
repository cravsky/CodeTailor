---
const { id = 'services', title, services } = Astro.props
---

<section id={id} class="bs-container bs-mt-lg">
  <!-- Header -->
  {title && <h2 class="bs-h2">{title}</h2>}

  <!-- Grid of steps -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
    {
      services.map((item) => (
        <article class="flex flex-col gap-4 p-6 rounded-xl border border-bs-surface-3 bg-bs-surface-0 h-full">
          {/* Title */}
          <h3 class="bs-h3" set:html={item.title} />

          {/* Content */}
          <div class="bs-body-text flex-1 text-pretty" set:html={item.content} />

          {/* Optional CTA */}
          {
            item.cta && (
              <button type="button" class="bs-btn inline-block self-start" onclick="demo.showModal()">
                {item.cta}
              </button>
            )
          }
        </article>
      ))
    }
  </div>
</section>
