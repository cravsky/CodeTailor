---

import Layout from "../layouts/Layout.astro"

import FaqSection from "../components/FaqSection.astro"
import ServicesCarousel from "../components/ServicesCarousel.astro"
import HeroSection from "../components/HeroSection.astro"
import NewsletterSection from "../components/NewsletterSection.astro"
import RescueSprintSection from "../components/RescueSprintSection.astro"
import SafeChangesSection from "../components/SafeChangesSection.astro"
import TrustSection from "../components/TrustSection.astro"
import TechnologiesSection from "../components/TechnologiesSection.astro"
import OngoingSupportSection from "../components/OngoingSupportSection.astro"
import PricingSection from "../components/PricingSection.astro"

import faq from "../data/faq.json"
import rescueSprint from "../data/offer/rescue_sprint.json"
import safeChanges from "../data/offer/safe_changes.json"
import trust from "../data/offer/trust.json"
import technologies from "../data/offer/technologies.json"
import ongoingSupport from "../data/offer/ongoing_support.json"
import services from "../data/services.json"
import home from "../data/home.json"
import pricing from "../data/pricing.json"
import global_settings from "../data/global_settings.json"
import newsletter from "../data/newsletter.json"

---

<Layout title={ global_settings.title }>

  <HeroSection
    content={ home.hero_content }
    settings={ global_settings }
    title={ home.hero_title }
  />

  <RescueSprintSection data={ rescueSprint } />

  <ServicesCarousel
    id="how-it-works"
    services={ services }
    title={ home.services_title }
  />

  <SafeChangesSection data={ safeChanges } />

  <TrustSection data={ trust } />

  <TechnologiesSection data={ technologies } />

  <PricingSection
    pricing={ pricing }
    title={ home.pricing_title }
  />

  <OngoingSupportSection data={ ongoingSupport } />

  <FaqSection
    faq={ faq }
    title={ home.faq_title }
  />

  <NewsletterSection newsletter={newsletter} />

</Layout>
